# Core
NODE_ENV=development          # development | production | test
PORT=3000                     # 0-65535

# Logging
# Optional. Defaults to "info" in production, "debug" otherwise.
# One of: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=debug

# Further config groups (DATABASE_URL, JWT_SECRET, RESEND_*, etc.) are added
# as their feature modules land — see docs/architecture.md.
