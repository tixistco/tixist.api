# Runtime environment: development | production | test
NODE_ENV=development

# Port the HTTP server listens on (0-65535)
PORT=3000

# Log level (optional). Defaults to "info" in production, "debug" otherwise.
# One of: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=debug

# --- Database (composed into DATABASE_URL below) ---

# Connection scheme: postgresql | postgres
DB_SCHEME=postgresql

# Database host
DB_HOST=localhost

# Database port
DB_PORT=5432

# Database user
DB_USER=postgres

# Database password
DB_PASSWORD=postgres

# Database name
DB_NAME=tixist

# Schema search path
DB_SCHEMA=public

# Effective Prisma connection string, composed from the DB_* parts above via
# dotenv variable expansion. Override the parts, not this line.
DATABASE_URL=${DB_SCHEME}://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=${DB_SCHEMA}

# --- Auth (JWT) ---

# Secret for signing access tokens (min 16 chars; use a long random value)
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
# Secret for signing refresh tokens (min 16 chars; distinct from the access secret)
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
# Access token lifetime (vercel/ms format, e.g. 15m, 1h)
JWT_ACCESS_TTL=15m
# Refresh token lifetime (e.g. 7d, 30d)
JWT_REFRESH_TTL=7d

# --- Cache (Redis) ---

# Redis connection string
REDIS_URL=redis://localhost:6379
# Seconds an authenticated user stays cached before re-reading from the DB
AUTH_CACHE_TTL=60
