// Prisma schema for tix-ist API.
// Grown incrementally per feature slice; see docs/data-model.md for the full
// target model. Money is stored as BigInt minor units; default currency NGN.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Application user / principal. Acts as event organizer and (later) team member.
/// JWT auth reuses the bcrypt `password` hash; NextAuth adapter tables are dropped.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String? // bcrypt hash; null for not-yet-set / external identities

  // SHA-256 digest of the current refresh token (single active session); null when logged out.
  hashedRefreshToken String?

  // Events this user organizes. Restrict delete: a user owning events can't be removed.
  events Event[] @relation("EventOrganizer")

  // Team collaboration
  teamMemberships TeamMember[] @relation("TeamMemberUser")
  invitedMembers  TeamMember[] @relation("TeamMemberInviter")
  invitationsSent Invitation[] @relation("InvitationSender")

  // Registrations made while authenticated (optional link)
  registrations Registration[]

  // Attendee profiles linked while authenticated (optional)
  attendees Attendee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Root aggregate — almost every other entity hangs off an event and cascade-deletes
/// with it. Relations to ticketing/team/audit models are added as those slices land.
model Event {
  id          String @id @default(cuid())
  slug        String @unique // URL-friendly identifier
  name        String
  description String @db.Text

  // Location & timing
  locationType    String // 'in-person' | 'virtual' | 'hybrid'
  locationAddress String? // physical address (in-person/hybrid)
  locationUrl     String? // virtual URL (virtual/hybrid)
  timezone        String   @default("UTC") // IANA timezone
  startDate       DateTime // stored in UTC
  endDate         DateTime // stored in UTC

  // Status & visibility
  status     String  @default("draft") // 'draft' | 'published' | 'archived'
  isArchived Boolean @default(false) // soft-delete flag

  // Ticket assignment configuration
  assignmentCutoffType  String    @default("event_start") // 'event_start' | '1h_before' | '24h_before' | 'custom'
  assignmentCutoffTime  DateTime? // used when type = 'custom'
  maxTicketsPerPurchase Int       @default(10)

  // Custom registration fields — array of CustomFieldDefinition objects
  customFields Json?

  // Organizer
  organizerId String
  organizer   User   @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Restrict)

  // Ticketing
  ticketTypes   TicketType[]
  registrations Registration[]
  tickets       Ticket[]

  // Team collaboration
  teamMembers TeamMember[]
  invitations Invitation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizerId])
  @@index([slug])
  @@index([status, isArchived])
  @@index([startDate])
  @@index([organizerId, status])
}

/// A purchasable ticket tier within an event. Price is stored in BigInt **minor
/// units** (e.g. kobo for NGN) to avoid float rounding; serialize it as an integer
/// string over the wire. Inventory is derived (`available = quantity − issued`), not
/// stored — the issued/registration count wires in when those models land.
model TicketType {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name        String
  description String @db.Text

  price    BigInt @default(0) // minor units; default currency NGN (kobo)
  currency String @default("NGN") // ISO 4217

  quantity  Int // total inventory
  saleStart DateTime? // null = no start restriction
  saleEnd   DateTime? // null = no end restriction

  registrations Registration[]
  tickets       Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@index([eventId, saleStart, saleEnd])
}

/// A purchase/order by a buyer; one registration covers `quantity` admissions. Inventory
/// is the SUM of a tier's registration quantities (cancelling hard-deletes the row, freeing
/// the slot). Self-registration is concurrency-safe: the tier row is locked `FOR UPDATE`
/// before counting, so capacity can't be oversold. Payment fields are dormant until the
/// processor lands; only free tiers are registrable for now.
model Registration {
  id String @id @default(cuid())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  ticketTypeId String
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)

  email String // buyer email
  name  String // buyer name

  userId String? // optional link if registered while authenticated
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  quantity Int @default(1)

  paymentStatus    String  @default("free") // free | pending | paid | failed | refunded
  paymentIntentId  String? // dormant until a processor lands
  paymentProcessor String? // 'stripe' | 'paystack' | null

  tickets Ticket[]

  registeredAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([eventId])
  @@index([ticketTypeId])
  @@index([email])
  @@index([userId])
  @@index([eventId, ticketTypeId])
  @@index([registeredAt])
}

/// An individual admission token — one per seat. Minted (unassigned) when a free
/// registration is created, in the same locked transaction. Carries a public-facing
/// `ticketNumber` and a high-entropy `qrCodeData` payload (the QR encodes this; image
/// rendering is a client concern). Assignment to an `Attendee` (the `attendeeId` 1:1 FK)
/// and check-in land in later slices — the columns exist now but aren't wired yet.
model Ticket {
  id String @id @default(cuid())

  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  ticketTypeId String
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)

  ticketNumber String @unique // human-readable, e.g. TKT-<ts>-<rand>
  qrCodeData   String @unique // high-entropy QR payload

  // Assignment to an attendee (1:1)
  isAssigned Boolean   @default(false)
  assignedAt DateTime?
  attendeeId String?   @unique
  attendee   Attendee? @relation(fields: [attendeeId], references: [id], onDelete: SetNull)

  // Check-in (wired in the CheckIn slice)
  isCheckedIn Boolean   @default(false)
  checkedInAt DateTime?
  checkedInBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([registrationId])
  @@index([eventId])
  @@index([ticketTypeId])
  @@index([ticketNumber])
  @@index([qrCodeData])
  @@index([eventId, isCheckedIn])
  @@index([eventId, isAssigned])
}

/// The person who will attend (distinct from the buyer/registrant), 1:1 with a `Ticket`.
/// Holds custom-field answers (validated against the event's `customFields`) and email
/// deliverability state. Created on ticket assignment; deleted on unassignment/reassignment.
model Attendee {
  id    String @id @default(cuid())
  name  String
  email String

  customData  Json? // CustomFieldResponses — answers keyed by field id
  emailStatus String @default("active") // active | bounced | unsubscribed

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  ticket Ticket? // 1:1 back-reference

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([userId])
  @@index([emailStatus])
}

enum TeamRole {
  OWNER
  COLLABORATOR
}

enum TeamMemberStatus {
  PENDING
  ACTIVE
  REMOVED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

/// A user's membership in one event's team. The source of truth for "can X act on
/// event Z": owners bypass module checks; collaborators are gated to `modulePermissions`.
/// `userId` is null while an invite is PENDING (keyed by email), backfilled on accept.
model TeamMember {
  id String @id @default(cuid())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId String? // null until the invitation is accepted
  user   User?   @relation("TeamMemberUser", fields: [userId], references: [id], onDelete: SetNull)

  email String // always present (target of the invite)

  role   TeamRole         @default(COLLABORATOR)
  status TeamMemberStatus @default(PENDING)

  modulePermissions String[] @default([]) // e.g. ["CFP","ATTENDEES"]; ignored for OWNER

  invitedById String
  invitedBy   User     @relation("TeamMemberInviter", fields: [invitedById], references: [id], onDelete: Restrict)
  invitedAt   DateTime @default(now())

  lastAccessedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, email])
  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([eventId, status])
  @@index([eventId, userId])
  @@index([eventId, role])
}

/// A pending team invite carrying a secure token (7-day expiry). Sending an invite
/// creates this plus a PENDING TeamMember in one transaction; accept/decline flips both.
model Invitation {
  id String @id @default(cuid())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  email             String
  token             String   @unique // randomBytes(32) base64url, 43 chars
  modulePermissions String[] @default([])

  status    InvitationStatus @default(PENDING)
  expiresAt DateTime // now() + 7 days

  sentById String
  sentBy   User     @relation("InvitationSender", fields: [sentById], references: [id], onDelete: Restrict)
  sentAt   DateTime @default(now())

  respondedAt DateTime?

  @@index([token])
  @@index([eventId])
  @@index([email])
  @@index([status, expiresAt])
  @@index([eventId, status])
}
